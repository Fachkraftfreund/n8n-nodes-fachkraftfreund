{
  "name": "n8n-nodes-fachkraftfreund",
  "version": "0.1.1",
  "description": "n8n community nodes for Fachkraftfreund - WaliChat and Ringover integrations",
  "license": "MIT",
  "keywords": [
    "n8n-community-node-package"
  ],
  "author": {
    "name": "Fachkraftfreund"
  },
  "main": "dist/nodes/WaliChat/WaliChat.node.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/WaliChatApi.credentials.js",
      "dist/credentials/RingoverApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/WaliChat/WaliChat.node.js",
      "dist/nodes/WaliChatFirstContacts/WaliChatFirstContacts.node.js",
      "dist/nodes/Ringover/Ringover.node.js"
    ]
  },
  "devDependencies": {
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0",
    "typescript": "~5.7.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
